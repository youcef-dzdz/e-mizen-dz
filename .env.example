# ==========================================
# SUPABASE — Dashboard: https://supabase.com/dashboard
# ==========================================

# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique anon — safe côté client, RLS protège les données
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service_role — UNIQUEMENT côté serveur (API routes)
# ⛔ Jamais dans du code client — bypasse RLS complètement (Rule 11)
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================
# GROQ — Assistant IA — Console: https://console.groq.com
# ==========================================

# Clé API Groq — endpoint streaming /api/ai/chat uniquement
GROQ_API_KEY=

# Modèle utilisé — ne pas changer sans mettre à jour docs/RAG.md
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================================
# RESEND — Emails transactionnels — https://resend.com/dashboard
# ==========================================

# Clé API Resend — notifications, confirmations, rappels
RESEND_API_KEY=

# Email expéditeur vérifié dans Resend
RESEND_FROM_EMAIL=noreply@e-mizen.dz

# ==========================================
# AUTH — Supabase Auth (Google OAuth)
# Config: Supabase Dashboard → Auth → Providers
# ==========================================

# URL de callback OAuth Google
# Format: https://[ref].supabase.co/auth/v1/callback
NEXT_PUBLIC_AUTH_CALLBACK_URL=

# ==========================================
# APP
# ==========================================

# URL de base — http://localhost:3000 en dev, URL Vercel en prod
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environnement courant
NODE_ENV=development

# ==========================================
# RAG — Pipeline IA (modifier après lecture docs/RAG.md)
# ==========================================

# Nombre max de chunks retournés par pgvector
RAG_TOP_K=5

# Nombre minimum de résultats avant de répondre
# En dessous → "Je n'ai pas trouvé d'article pertinent"
RAG_MIN_RESULTS=3

# Seuil de similarité cosinus (0-1) — en dessous: chunk ignoré
RAG_SIMILARITY_THRESHOLD=0.7

# ==========================================
# RATE LIMITING (Rule 18 — par user, pas par IP)
# ==========================================

# Max requêtes IA par user par heure
RATE_LIMIT_AI_PER_HOUR=20

# Max uploads par user par jour
RATE_LIMIT_UPLOADS_PER_DAY=10
